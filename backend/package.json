{
  "name": "backend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "tsc && node -e \"const fs=require('fs'); const path=require('path'); const distPath=path.join(__dirname,'dist','server.js'); if(!fs.existsSync(distPath)){console.error('ERROR: dist/server.js was not created!'); process.exit(1);} else {console.log('✓ Build successful: dist/server.js exists');}\"",
    "start": "node dist/server.js",
    "seed": "ts-node-dev --transpile-only src/scripts/seed.ts"
  },
  "dependencies": {
    "@clerk/clerk-sdk-node": "^5.0.0",
    "@clerk/express": "^1.7.46",
    "@types/fs-extra": "^11.0.4",
    "@types/multer": "^2.0.0",
    "axios": "^1.13.6",
    "cloudinary": "^1.41.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "fs-extra": "^11.3.4",
    "groq-sdk": "^1.1.1",
    "mongoose": "^8.19.3",
    "multer": "^2.0.2",
    "path": "^0.12.7",
    "pusher": "^5.1.3",
    "svix": "^1.90.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.7.4",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.6.3"
  }
}
